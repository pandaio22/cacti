{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "composite": true,
      "module": "ESNext",
      //"target": "ES2021",
      "outDir": "./dist/lib/",
      "declarationDir": "dist/lib",
      "allowJs": false,
      "rootDir": "./src/",
      "tsBuildInfoFile": "../../.build-cache/cacti-asset-schema-architecture-plugin-satp.tsbuildinfo",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "typeRoots": ["./src/main/typescript/types", "./node_modules/@types"]
    },
    "ts-node": {
      "files": true,
      "esm": false
    },
    "include": [
      "./src",
      "src/**/*.json"
    ]
  }