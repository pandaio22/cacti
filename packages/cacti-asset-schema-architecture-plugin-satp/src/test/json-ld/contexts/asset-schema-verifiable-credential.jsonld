{
  "@context": {
    "id": "@id",
    "type": "@type",
    "VerifiableCredential": "https://www.w3.org/2018/credentials#VerifiableCredential",
    "AssetSchemaVerifiableCredential": "https://example.com/AssetSchemaVerifiableCredential",
    "issuer": { "@id": "https://www.w3.org/2018/credentials#issuer", "@type": "@id" },
    "issuanceDate": { "@id": "https://www.w3.org/2018/credentials#issuanceDate", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },
    "credentialSubject": { "@id": "https://www.w3.org/2018/credentials#credentialSubject", "@type": "@id" },
    "name": "https://schema.org/name",
    "version": "https://example.com/version",
    "hash": "https://example.com/hash",
    "commissionedBy": { "@id": "https://example.com/commissionedBy", "@type": "@id" },
    "createdBy": { "@id": "https://example.com/createdBy", "@type": "@id" }
  }
}
