          "default": "localhost"
        },
        "port": {
          "default": "3000"
        }
      }
    },
    {
      "url": "http://{host}:{port}/api/@hyperledger/cacti-asset-schema-architecture/asset-schema-authority",
      "description": "Asset Schema Authority server",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "3010"
        }
      }
    },
    {
      "url": "http://{host}:{port}/api/@hyperledger/cacti-asset-schema-architecture/asset-provider",
      "description": "Asset Provider server",
      "variables": {
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "3020"
        }
