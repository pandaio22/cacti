{
  "name": "@hyperledger/cacti-asset-schema-architecture-plugin-satp",
  "version": "2.1.0",
  "description": "An implementation of the asset schema architecture used to setup assets to transfer using SATP",
  "main": "dist/lib/main/typescript/index.js",
  "module": "dist/lib/main/typescript/index.js",
  "types": "dist/lib/main/typescript/index.d.ts",
  "files": [
    "dist/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandaio22/cacti.git#satp-dev-thesis"
  },
  "keywords": [
    "SATP",
    "Distributed-Ledger-Technology",
    "Interoperability",
    "Assets"
  ],
  "author": "Rodolfo Carapau <rodolfo.carapau@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pandaio22/cacti/issues"
  },
  "homepage": "https://github.com/pandaio22/cacti/tree/satp-dev-thesis#readme",
  "scripts": {
    "bundle-openapi-json": "swagger-cli bundle ./src/main/yml/openapi-asset-schema-architecture.yml -o ./src/main/json/openapi-asset-schema-architecture-bundled.json -r -t json",
    "bundle-openapi-yml": "swagger-cli bundle ./src/main/yml/openapi-asset-schema-architecture.yml -o ./src/main/yml/openapi-asset-schema-architecture-bundled.yml -r -t yaml",
    "codegen:openapi": "yarn bundle-openapi-yml && yarn bundle-openapi-json && npx openapi-generator-cli generate -i ./src/main/yml/openapi-asset-schema-architecture-bundled.yml -g typescript-axios -o ./src/main/typescript/generated/asset-schema-architecture/typescript-axios/ --reserved-words-mappings protected=protected --enable-post-process-file",
    "start:plugin": "node ./dist/lib/main/typescript/plugin-asset-schema-architecture-cli.js",
    "test:unit": "npx jest ./src/test/typescript/unit --detectOpenHandles --runInBand",
    "test:integration": "npx jest ./src/test/typescript/integration/entities --detectOpenHandles --runInBand",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "watch": "tsc --build --watch"
  },
  "dependencies": {
    "@digitalcredentials/jsonld": "9.0.0",
    "@helia/json": "4.0.6",
    "@helia/strings": "4.0.6",
    "@hyperledger/cactus-api-client": "workspace:^",
    "@hyperledger/cactus-cmd-api-server": "workspace:^",
    "@hyperledger/cactus-common": "workspace:^",
    "@hyperledger/cactus-core": "workspace:^",
    "@hyperledger/cactus-core-api": "workspace:^",
    "@hyperledger/cactus-plugin-object-store-ipfs": "workspace:^",
    "@hyperledger/cactus-plugin-satp-hermes": "workspace:^",
    "@peculiar/webcrypto": "1.5.0",
    "asn1js": "3.0.6",
    "body-parser": "2.2.0",
    "class-validator": "^0.14.2",
    "crypto": "1.0.1",
    "express": "5.1.0",
    "helia": "5.4.2",
    "jose": "5",
    "jsonld": "8.3.3",
    "jsonld-signatures": "11.5.0",
    "kubo-rpc-client": "5.1.0",
    "multiformats": "13.3.6",
    "node-forge": "1.3.1",
    "pkijs": "3.2.5",
    "pvutils": "1.1.3",
    "safe-stable-stringify": "2.5.0",
    "supertest": "^7.1.1",
    "uuid": "11.1.0",
    "zod": "3.24.4",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.20.2",
    "@types/express": "5",
    "@types/jest": "29.5.14",
    "@types/jsonld": "1.5.15",
    "@types/node": "22.15.21",
    "@types/node-forge": "1",
    "@types/supertest": "^6.0.3",
    "jest": "29.7.0",
    "swagger-cli": "4.0.4",
    "ts-jest": "29.3.4",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "publishConfig": {
    "access": "public"
  },
  "watch": {
    "tsc": {
      "patterns": [
        "src/",
        "src/*/yml/**/*"
      ],
      "ignore": [
        "src/**/generated/*"
      ],
      "extensions": [
        "ts",
        "yml"
      ],
      "quiet": true,
      "verbose": false,
      "runOnChangeOnly": true
    }
  }
}
