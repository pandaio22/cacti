{
  "name": "@hyperledger/cacti-asset-schema-architecture-plugin-satp",
  "version": "2.1.0",
  "description": "An implementation of the asset schema architecture used to setup assets to transfer using SATP",
  "main": "dist/lib/main/typescript/index.js",
  "module": "dist/lib/main/typescript/index.js",
  "types": "dist/lib/main/typescript/index.d.ts",
  "files": [
    "dist/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandaio22/cacti.git#satp-dev-thesis"
  },
  "keywords": [
    "SATP",
    "Distributed-Ledger-Technology",
    "Interoperability",
    "Assets"
  ],
  "author": "Rodolfo Carapau <rodolfo.carapau@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pandaio22/cacti/issues"
  },
  "homepage": "https://github.com/pandaio22/cacti/tree/satp-dev-thesis#readme",
  "scripts": {
    "bundle-openapi-json": "swagger-cli bundle ./src/main/yml/openapi-asset-schema-architecture.yml -o ./src/main/json/openapi-asset-schema-architecture-bundled.json -r -t json",
    "bundle-openapi-yml": "swagger-cli bundle ./src/main/yml/openapi-asset-schema-architecture.yml -o ./src/main/yml/openapi-asset-schema-architecture-bundled.yml -r -t yaml",
    "codegen:openapi": "yarn bundle-openapi-yml && yarn bundle-openapi-json && npx openapi-generator-cli generate -i ./src/main/yml/openapi-asset-schema-architecture-bundled.yml -g typescript-axios -o ./src/main/typescript/generated/asset-schema-architecture/typescript-axios/ --reserved-words-mappings protected=protected --enable-post-process-file",
    "start:plugin": "node ./dist/lib/main/typescript/plugin-asset-schema-architecture-cli.js",
    "test:vitest:unit": "vitest run ./src/test/typescript/unit --run",
    "test:vitest:integration": "vitest run ./src/test/typescript/integration/entities --run",
    "test:vitest:integration:asset-schema-authority": "vitest run ./src/test/typescript/integration/entities/asset-schema-authority --run",
    "test:vitest:integration:registry": "vitest run ./src/test/typescript/integration/entities/registry --run",
    "test:vitest:integration:asset-provider": "vitest run ./src/test/typescript/integration/entities/asset-provider --run",
    "test:vitest:integration:all": "yarn test:vitest:integration:asset-schema-authority && yarn test:vitest:integration:registry && yarn test:vitest:integration:asset-provider",
    "test:vitest:system": "vitest run ./src/test/typescript/system/**/*.system.test.ts --run --sequence.concurrent=false --sequence.shuffle=false --max-workers=1",
    "test:jest:unit": "npx jest ./src/test/typescript/unit --detectOpenHandles --runInBand",
    "test:jest:integration": "npx jest ./src/test/typescript/integration/entities --detectOpenHandles --runInBand",
    "test:jest:integration:asset-schema-authority": "npx jest ./src/test/typescript/integration/entities/asset-schema-authority --detectOpenHandles --runInBand",
    "test:jest:integration:registry": "npx jest ./src/test/typescript/integration/entities/registry --detectOpenHandles --runInBand",
    "test:jest:integration:asset-schema-provider": "npx jest ./src/test/typescript/integration/entities/asset-provider --detectOpenHandles --runInBand",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:specific": "vitest run --grep",
    "db:migrate": "knex --knexfile ./src/main/typescript/entities/registry/modules/database/knex/knexfile.ts migrate:latest",
    "watch": "tsc --build --watch"
  },
  "dependencies": {
    "@digitalbazaar/data-integrity": "^2.5.0",
    "@digitalbazaar/did-method-key": "^5.2.0",
    "@digitalbazaar/ed25519-signature-2020": "^5.4.0",
    "@digitalbazaar/ed25519-verification-key-2020": "^4.2.0",
    "@digitalbazaar/eddsa-rdfc-2022-cryptosuite": "^1.2.0",
    "@digitalbazaar/vc": "^7.2.0",
    "@digitalcredentials/jsonld": "9.0.0",
    "@helia/json": "4.0.6",
    "@helia/strings": "4.0.6",
    "@hyperledger/cactus-api-client": "workspace:^",
    "@hyperledger/cactus-cmd-api-server": "workspace:^",
    "@hyperledger/cactus-common": "workspace:^",
    "@hyperledger/cactus-core": "workspace:^",
    "@hyperledger/cactus-core-api": "workspace:^",
    "@hyperledger/cactus-plugin-object-store-ipfs": "workspace:^",
    "@hyperledger/cactus-plugin-satp-hermes": "workspace:^",
    "@peculiar/webcrypto": "1.5.0",
    "@veramo/core": "^6.0.0",
    "@veramo/credential-ld": "^6.0.0",
    "@veramo/credential-w3c": "^6.0.0",
    "@veramo/data-store": "^6.0.0",
    "@veramo/did-manager": "^6.0.0",
    "@veramo/did-provider-ethr": "^6.0.0",
    "@veramo/did-provider-web": "^6.0.0",
    "@veramo/did-resolver": "^6.0.0",
    "@veramo/key-manager": "^6.0.0",
    "@veramo/kms-local": "^6.0.0",
    "asn1js": "3.0.6",
    "body-parser": "2.2.0",
    "class-validator": "^0.14.2",
    "crypto": "1.0.1",
    "dotenv": "^17.2.1",
    "ethr-did-resolver": "^11.0.5",
    "express": "5.1.0",
    "helia": "5.4.2",
    "jose": "5",
    "jsonld": "^8.3.3",
    "jsonld-signatures": "^11.5.0",
    "knex": "^3.1.0",
    "kubo-rpc-client": "5.1.0",
    "multiformats": "13.3.6",
    "node-forge": "1.3.1",
    "pg": "^8.16.3",
    "pkijs": "3.2.5",
    "pvutils": "1.1.3",
    "safe-stable-stringify": "2.5.0",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.1",
    "uuid": "11.1.0",
    "web-did-resolver": "^2.0.30",
    "zod": "3.24.4",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@openapitools/openapi-generator-cli": "^2.20.2",
    "@types/babel__core": "^7",
    "@types/babel__preset-env": "^7",
    "@types/express": "5",
    "@types/jest": "29.5.14",
    "@types/jsonld": "1.5.15",
    "@types/knex": "^0.16.1",
    "@types/node": "22.15.21",
    "@types/node-forge": "1",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^3.2.4",
    "babel-loader": "^10.0.0",
    "jest": "29.7.0",
    "swagger-cli": "4.0.4",
    "ts-jest": "29.3.4",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vitest": "^3.2.4",
    "webpack": "^5.101.1"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "publishConfig": {
    "access": "public"
  },
  "watch": {
    "tsc": {
      "patterns": [
        "src/",
        "src/*/yml/**/*"
      ],
      "ignore": [
        "src/**/generated/*"
      ],
      "extensions": [
        "ts",
        "yml"
      ],
      "quiet": true,
      "verbose": false,
      "runOnChangeOnly": true
    }
  },
  "overrides": {
    "jsonld": "npm:@digitalcredentials/jsonld@^8.3.3"
  },
  "type": "module"
}
